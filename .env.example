# Google Drive - OAuth 2.0 (Nisan 2025 sonrası Service Account çalışmıyor)
# 1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
# 2. Application type: Web application
# 3. Authorized redirect URIs: http://localhost:3010/api/drive-auth/callback (ve sunucu URL'niz)
# 4. Drive API'yi etkinleştir
# 5. Sunucuyu başlat, tarayıcıda GET /api/drive-auth ile yetkilendir
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxx

# Drive'da dosyaların yükleneceği klasör ID (My Drive'da herhangi bir klasör)
GOOGLE_DRIVE_ROOT_FOLDER_ID=1abc...xyz
