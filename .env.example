# Google Drive API - Service Account JSON dosyası yolu
# API key yeterli değil, Service Account gerekli:
# 1. Google Cloud Console → APIs & Services → Credentials
# 2. Create Service Account → Keys → Add Key → JSON
# 3. Drive API'yi etkinleştir
# 4. Klasör oluşturmak için: Drive'da bir klasör oluştur, Service Account email ile paylaş
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Opsiyonel: Dosyaların yükleneceği ana klasör ID (Service Account ile paylaşılmış)
# GOOGLE_DRIVE_ROOT_FOLDER_ID=1abc...xyz
